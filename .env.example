# =========================================================
# OPTIONAL LOCAL AI / LLM MODULES
# =========================================================

# Ollama
OLLAMA_URL=http://127.0.0.1:11434

# Local LLM API
LOCAL_LLM_API_URL=http://127.0.0.1:8000

# Local model name
LOCAL_LLM_MODEL=

# OpenAI-compatible local endpoint
LOCAL_OPENAI_COMPAT_URL=

# =========================================================
# OPTIONAL LOCAL BACKEND
# =========================================================

# FastAPI local backend
VERA5_BACKEND_URL=http://127.0.0.1:8000

# Backend auth secret (local only)
VERA5_LOCAL_SECRET=

# SQLite path
VERA5_SQLITE_PATH=

# Redis cache (optional)
VERA5_REDIS_URL=

# =========================================================
# CACHE / PERFORMANCE
# =========================================================

# Cache TTL in seconds
CACHE_TTL=3600

# Maximum cache entries
CACHE_MAX_ENTRIES=10000

# Request timeout
REQUEST_TIMEOUT_SECONDS=15

# =========================================================
# DEBUG / DEVELOPMENT
# =========================================================

# Debug logging
DEBUG=false

# Verbose IOC logs
VERBOSE_LOGGING=false

# Enable dev overlays
DEV_OVERLAYS=false

# Mock enrichment mode
MOCK_MODE=false

# =========================================================
# EXTENSION / SECURITY
# =========================================================

# Manual-only mode default
MANUAL_ONLY_MODE=true

# Disable telemetry
TELEMETRY_ENABLED=false

# Disable crash reporting
CRASH_REPORTING=false

# Allowed localhost origins
LOCALHOST_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# =========================================================
# EXPORTS / REPORTING
# =========================================================

# Markdown export enabled
EXPORT_MARKDOWN=true

# JSON export enabled
EXPORT_JSON=true

# CSV export enabled
EXPORT_CSV=false

# =========================================================
# FUTURE MODULES (PLACEHOLDERS)
# =========================================================

# YARA enrichment
YARA_ENGINE_PATH=

# Sigma rule mapping
SIGMA_RULESET_PATH=

# ATT&CK enrichment
ATTACK_DATASET_PATH=

# STIX/TAXII
TAXII_SERVER_URL=
TAXII_USERNAME=
TAXII_PASSWORD=

# =========================================================
# IMPORTANT
# =========================================================
# THIS FILE IS AN EXAMPLE TEMPLATE ONLY.
#
# NEVER:
# - commit real credentials
# - upload populated .env files
# - paste secrets into AI chats
#
# ALWAYS:
# - use local-only storage
# - rotate compromised keys
# - review vendor rate limits
# - follow vendor ToS
#
# Vera5:
# Local-first
# Open-source
# Analyst-focused
# BYOK/BYOA
# No mandatory cloud infrastructure
# =========================================================