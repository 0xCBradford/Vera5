{
  "name": "vera5-extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Vera5 browser extension — IOC enrichment overlay",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build -c vite.content.config.ts",
    "build:watch": "vite build --watch",
    "icons": "node scripts/generate-icons.mjs",
    "verify:dist": "node scripts/verify-dist-manifest.mjs",
    "verify:security": "node scripts/verify-extension-security.mjs",
    "postbuild": "npm run verify:dist && npm run verify:security",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:smoke": "vitest run src/background/messageHandler.smoke.test.ts",
    "test:e2e": "node scripts/verify-dist-manifest.mjs && playwright test",
    "test:e2e:critical": "node scripts/verify-dist-manifest.mjs && playwright test e2e/harness.load.spec.ts e2e/scan.sample-alert.spec.ts e2e/popup.tray.spec.ts e2e/hoverCard.disclaimer.spec.ts e2e/hoverCard.compositeScore.spec.ts e2e/commandPalette.scan.spec.ts e2e/export.clipboard.spec.ts e2e/trayEnrichQueue.spec.ts",
    "test:e2e:install": "playwright install chromium",
    "check": "npm run lint && npm run test",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "@types/chrome": "^0.0.323",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.5.3",
    "sharp": "^0.35.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.5",
    "vitest": "4.1.8"
  }
}
