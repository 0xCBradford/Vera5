{
  "manifest_version": 3,
  "name": "Vera5",
  "description": "IOC enrichment for analyst workflows. storage: local API keys and enrichment cache. activeTab: run only on the tab you are viewing. scripting: inject IOC detection on demand. host_permissions: read page text on sites you visit; live enrichment sends IOC values over HTTPS GET only to declared vendor API hosts you enable (AbuseIPDB, OTX, URLScan.io, GreyNoise, Shodan, Censys, VirusTotal).",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "sidePanel"],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://api.abuseipdb.com/*",
    "https://otx.alienvault.com/*",
    "https://urlscan.io/*",
    "https://api.greynoise.io/*",
    "https://www.virustotal.com/*",
    "https://api.shodan.io/*",
    "https://search.censys.io/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Vera5",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "commands": {
    "scan-page": {
      "description": "Scan the current page for indicators",
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    },
    "command-palette": {
      "description": "Open the Vera5 command palette",
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      }
    }
  }
}
